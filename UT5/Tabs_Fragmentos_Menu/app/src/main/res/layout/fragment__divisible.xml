<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Fragment_Divisible">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <RadioGroup
            android:id="@+id/radioGroupDivisibles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="32dp">

            <RadioButton
                android:id="@+id/radioDiv2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Divisible entre 2"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioDiv3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Divisible entre 3"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioDiv5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Divisible entre 5"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioDiv10"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Divisible entre 10"
                android:textSize="16sp" />

            <RadioButton
                android:id="@+id/radioNinguno"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No es divisible entre ninguno"
                android:textSize="16sp" />

        </RadioGroup>

        <Button
            android:id="@+id/btnValidarDivisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Validar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/radioGroupDivisibles"
            android:layout_marginTop="32dp" />

        <TextView
            android:id="@+id/txtResultadoDivisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Pendiente"
            android:textColor="@android:color/holo_blue_bright"
            android:textSize="34sp"
            app:layout_constraintStart_toEndOf="@id/btnValidarDivisible"
            app:layout_constraintTop_toBottomOf="@id/radioGroupDivisibles"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>